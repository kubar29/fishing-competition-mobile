{
  "expo": {
    "name": "Fishing Competition",
    "slug": "fishing-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/icon.png",

    "scheme": "fishingmobileapp",
    "backgroundColor": "#0B1220",
    "userInterfaceStyle": "dark",

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "edgeToEdgeEnabled": true
    },

    "web": {
      "output": "static"
    },

    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}